# Laravel
*.log
.env
.env.backup
.env.production
.phpactor.json
.phpunit.result.cache

# IDE
/.fleet
/.idea
/.nova
/.phpunit.cache
/.vscode
/.zed
/auth.json

# Dependencies — restore via: composer install && npm install
/vendor
/node_modules

# Vite compiled output — restore via: npm run build
/public/build
/public/hot

# Storage — runtime files & user-uploaded media (not tracked in git)
/storage/app/public/*
!/storage/app/public/.gitkeep
/storage/framework/cache/data/*
!/storage/framework/cache/data/.gitkeep
/storage/framework/sessions/*
!/storage/framework/sessions/.gitkeep
/storage/framework/testing/*
!/storage/framework/testing/.gitkeep
/storage/framework/views/*
!/storage/framework/views/.gitkeep
/storage/logs/*
!/storage/logs/.gitkeep
/storage/*.key
/storage/pail

# Public storage symlink — restore via: php artisan storage:link
/public/storage

# Compiled bootstrap cache — restore via: php artisan config:cache
/bootstrap/cache/*.php
!/bootstrap/cache/.gitignore

# SQLite dev database
/database/*.sqlite
/database/*.sqlite-journal
/database/*.sqlite-wal
/database/*.sqlite-shm

# OS
.DS_Store
Thumbs.db
Homestead.json
Homestead.yaml
